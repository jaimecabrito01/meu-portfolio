---
import MainLayout from "../layouts/MainLayout.astro";
import Box from "../components/Box.astro";
---

<MainLayout title="Blog - Jaime Victor">

<Box title=">> BLOG EM CONSTRUÇÃO">

    <div class="construction-layout">

        <div class="gif-column">

            <img src="/gifs/exclame.gif" alt="!" />
            <img src="/gifs/constrct.gif" alt="Construction" />

        </div>

        <div class="main-content">

            <div class="construction">
                🚧
            </div>

            <h2 class="blink">
                PÁGINA EM CONSTRUÇÃO
            </h2>

            <p>
                O blog ainda está sendo desenvolvido.
            </p>

            <p>
                Em breve serão publicados conteúdos sobre:
            </p>

            <ul class="topic-list">
                <li>Linux</li>
                <li>Java e Spring Boot</li>
                <li>DevOps</li>
                <li>Docker</li>
                <li>Cloud Computing</li>
                <li>Home Lab</li>
                <li>Redes de Computadores</li>
                <li>Servidores Linux</li>
                <li>Arquitetura Backend</li>
                <li>Projetos Pessoais</li>
            </ul>

            <br />

            <div class="counter">
                ÚLTIMA ATUALIZAÇÃO: 31/05/2026
            </div>

        </div>

        <div class="gif-column">

            <img src="/gifs/exclame.gif" alt="!" />

        </div>

    </div>

</Box>

<div class="footer-note">
    Best viewed with Netscape Navigator • 800x600 • Java Enabled
</div>

</MainLayout>

<style>
    .construction-layout {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: 25px;
    }

    .gif-column {
        width: 120px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
    }

    .gif-column img {
        max-width: 88px;
        height: auto;
    }

    .main-content {
        flex: 1;
        max-width: 500px;
        text-align: center;
    }

    .construction {
        font-size: 80px;
        margin: 15px 0;
    }

    .blink {
        animation: blink 1s infinite;
    }

    @keyframes blink {
        50% {
            opacity: 0;
        }
    }

    .topic-list {
        display: inline-block;
        text-align: left;
        margin-top: 10px;
    }

    .footer-note {
        text-align: center;
        color: #c0c0c0;
        margin-top: 15px;
        font-size: 12px;
        font-family: "Courier New", monospace;
    }
</style>