---
import MainLayout from "../layouts/MainLayout.astro";
import Box from "../components/Box.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { updates } from "../data/updates.js";

const latest = updates
    .sort((a, b) => new Date(b.date) - new Date(a.date))
    .slice(0, 5);
---

<MainLayout title="Jaime Victor - Home">

<Box title=">> BEM-VINDO">
    <Hero />
</Box>

<div class="grid">

    <Box title=">> PROJETOS EM DESTAQUE">

        <ProjectCard
            title="Api de Receitas"
            description="Aplicação full-stack para gerenciamento de receitas culinárias com Spring Boot e Vue 3."
            link="https://github.com/jaimecabrito01/Api-receitas"
        />

        <br />

        <ProjectCard
            title="File Mover"
            description="Utilitário que organiza automaticamente os downloads movendo arquivos para pastas por tipo."
            link="https://github.com/jaimecabrito01/file-mover"
        />

        <br />

        <a href="/projetos">
            Ver todos os projetos →
        </a>

    </Box>

    <Box title=">> ÚLTIMAS ATUALIZAÇÕES">

        {latest.map(({ date, text }) => {
            const [ano, mes, dia] = date.split("-");
            return <p>[{dia}/{mes}/{ano}] {text}</p>;
        })}

        <br />

        <a href="/blog">
            Ler blog →
        </a>

    </Box>

</div>

<Box title=">> TECNOLOGIAS FAVORITAS">

    Java • Spring Boot • Linux • Docker • Git • PostgreSQL • AWS • Bash • HTML • CSS

</Box>

<Box title=">> ACESSO RÁPIDO">

    <ul>
        <li><a href="/sobre">Conheça minha trajetória</a></li>
        <li><a href="/projetos">Veja meus projetos</a></li>
        <li><a href="/blog">Leia meus artigos</a></li>
        <li><a href="/contato">Entre em contato</a></li>
    </ul>

</Box>

</MainLayout>
